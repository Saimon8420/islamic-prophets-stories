import type { StoryChapter } from '../../../types/prophet';

const chapters: StoryChapter[] = [
  {
    id: 'isa-ch-01',
    title: 'Maryam: The Chosen One Above the Women of the Worlds',
    summary: 'Before the birth of Isa, Allah chose and honoured the family of Imran above all others. Maryam — daughter of Imran — was dedicated to the worship of Allah from before her birth, placed under the guardianship of Prophet Zakariya, and sustained with miraculous provisions. Her purity and devotion prepared the way for the greatest miracle: the birth of a prophet without a father.',
    order: 1,
    paragraphs: [
      {
        id: 'isa-ch01-p01',
        text: 'The story of Prophet Isa (Jesus, AS) begins not with his own birth, but with the extraordinary family from which he came. Allah chose the family of Imran above all of creation, just as He had chosen Adam, Nuh, and the family of Ibrahim before them. Imran\'s wife — the grandmother of Isa — was a woman of deep piety. When she became pregnant, she made a remarkable vow: "My Lord, indeed I have pledged to You what is in my womb, consecrated [for Your service], so accept this from me." She dedicated her unborn child entirely to the service of Allah, expecting a son who would serve in the temple. But when she gave birth to a girl — Maryam — she said: "My Lord, I have delivered a female... and I have named her Maryam, and I seek refuge in You for her and her descendants from Satan, the expelled." Allah accepted Maryam with a "good acceptance" — meaning He took her under His direct care and protection. She was placed under the guardianship of Prophet Zakariya, who found something extraordinary: every time he entered her prayer chamber, he found provisions already there. When he asked, "O Maryam, from where is this [coming] to you?" she replied: "It is from Allah. Indeed, Allah provides for whom He wills without account." Ibn Kathir explains that this miraculous provision was a sign from Allah that Maryam was no ordinary girl — she was being prepared for an extraordinary role in the history of prophethood.',
        phase: 'quran',
        references: [
          {
            type: 'quran',
            surah: 3,
            surahName: { en: 'Al-Imran', bn: 'আলে-ইমরান', ar: 'آل عمران' },
            ayahStart: 33,
            ayahEnd: 37,
            arabicText: 'إِنَّ اللَّهَ اصْطَفَىٰ آدَمَ وَنُوحًا وَآلَ إِبْرَاهِيمَ وَآلَ عِمْرَانَ عَلَى الْعَالَمِينَ ذُرِّيَّةً بَعْضُهَا مِن بَعْضٍ ۗ وَاللَّهُ سَمِيعٌ عَلِيمٌ ... كُلَّمَا دَخَلَ عَلَيْهَا زَكَرِيَّا الْمِحْرَابَ وَجَدَ عِندَهَا رِزْقًا ۖ قَالَ يَا مَرْيَمُ أَنَّىٰ لَكِ هَٰذَا ۖ قَالَتْ هُوَ مِنْ عِندِ اللَّهِ ۖ إِنَّ اللَّهَ يَرْزُقُ مَن يَشَاءُ بِغَيْرِ حِسَابٍ',
            translation: {
              en: 'Indeed, Allah chose Adam and Nuh and the family of Ibrahim and the family of Imran over the worlds — descendants, some of them from others. And Allah is Hearing and Knowing. ... Every time Zakariya entered upon her in the prayer chamber, he found with her provision. He said, "O Maryam, from where is this [coming] to you?" She said, "It is from Allah. Indeed, Allah provides for whom He wills without account."',
              bn: 'নিশ্চয়ই আল্লাহ আদম, নূহ, ইবরাহীমের বংশধর এবং ইমরানের বংশধরকে বিশ্ববাসীর উপর মনোনীত করেছেন — একে অপরের বংশধর। আল্লাহ সর্বশ্রোতা, সর্বজ্ঞ। ... যখনই যাকারিয়া তার কামরায় প্রবেশ করতেন, তার কাছে খাদ্যদ্রব্য পেতেন। তিনি বলতেন, "হে মারইয়াম, এটা তোমার কাছে কোথা থেকে আসে?" সে বলত, "এটা আল্লাহর পক্ষ থেকে। নিশ্চয়ই আল্লাহ যাকে ইচ্ছা বেহিসাব রিযিক দান করেন।"',
              ar: 'إِنَّ اللَّهَ اصْطَفَىٰ آدَمَ وَنُوحًا وَآلَ إِبْرَاهِيمَ وَآلَ عِمْرَانَ عَلَى الْعَالَمِينَ ذُرِّيَّةً بَعْضُهَا مِن بَعْضٍ ۗ وَاللَّهُ سَمِيعٌ عَلِيمٌ ... كُلَّمَا دَخَلَ عَلَيْهَا زَكَرِيَّا الْمِحْرَابَ وَجَدَ عِندَهَا رِزْقًا ۖ قَالَ يَا مَرْيَمُ أَنَّىٰ لَكِ هَٰذَا ۖ قَالَتْ هُوَ مِنْ عِندِ اللَّهِ ۖ إِنَّ اللَّهَ يَرْزُقُ مَن يَشَاءُ بِغَيْرِ حِسَابٍ'
            }
          }
        ]
      },
      {
        id: 'isa-ch01-p02',
        text: 'Maryam grew into a woman of unparalleled devotion. Allah chose her twice — once in her selection and again in her purification — and commanded her to be obedient to her Lord: "O Maryam, indeed Allah has chosen you and purified you and chosen you above the women of the worlds. O Maryam, be devoutly obedient to your Lord and prostrate and bow with those who bow [in prayer]." The double mention of being "chosen" emphasises the extraordinary nature of her selection. She was not merely pious — she was specifically chosen by Allah above every other woman in all of human history. Ibn Kathir notes that this distinction was earned through her absolute dedication to worship, her chastity, her trust in Allah, and her willingness to accept whatever Allah decreed for her — even when it meant bearing the heaviest trial any woman has ever faced. The Prophet Muhammad (SAW) confirmed her supreme status, saying: "The best of the world\'s women are four: Maryam daughter of Imran, Asiyah wife of Pharaoh, Khadijah daughter of Khuwaylid, and Fatimah daughter of Muhammad." Maryam\'s inclusion at the head of this list, named specifically in the Quran unlike any other woman, testifies to her unique rank in the sight of Allah.',
        phase: 'quran',
        references: [
          {
            type: 'quran',
            surah: 3,
            surahName: { en: 'Al-Imran', bn: 'আলে-ইমরান', ar: 'آল عمران' },
            ayahStart: 42,
            ayahEnd: 43,
            arabicText: 'وَإِذْ قَالَتِ الْمَلَائِكَةُ يَا مَرْيَمُ إِنَّ اللَّهَ اصْطَفَاكِ وَطَهَّرَكِ وَاصْطَفَاكِ عَلَىٰ نِسَاءِ الْعَالَمِينَ يَا مَرْيَمُ اقْنُتِي لِرَبِّكِ وَاسْجُدِي وَارْكَعِي مَعَ الرَّاكِعِينَ',
            translation: {
              en: 'And [mention] when the angels said, "O Maryam, indeed Allah has chosen you and purified you and chosen you above the women of the worlds. O Maryam, be devoutly obedient to your Lord and prostrate and bow with those who bow [in prayer]."',
              bn: 'আর যখন ফেরেশতারা বলল, "হে মারইয়াম, নিশ্চয়ই আল্লাহ তোমাকে মনোনীত করেছেন, তোমাকে পবিত্র করেছেন এবং বিশ্বের নারীদের উপর তোমাকে মনোনীত করেছেন। হে মারইয়াম, তোমার রবের প্রতি বিনীত হও, সিজদা করো এবং রুকুকারীদের সাথে রুকু করো।"',
              ar: 'وَإِذْ قَالَتِ الْمَلَائِكَةُ يَا مَرْيَمُ إِنَّ اللَّهَ اصْطَفَاكِ وَطَهَّرَكِ وَاصْطَفَاكِ عَلَىٰ نِسَاءِ الْعَالَمِينَ يَا مَرْيَمُ اقْنُتِي لِرَبِّكِ وَاسْجُدِي وَارْكَعِي مَعَ الرَّاكِعِينَ'
            }
          },
          {
            type: 'hadith',
            collection: 'Sahih al-Bukhari',
            hadithNumber: '3432',
            narrator: 'Ali ibn Abi Talib',
            text: {
              en: 'The Prophet (SAW) said: "The best of the world\'s women are four: Maryam daughter of Imran, Asiyah wife of Pharaoh, Khadijah daughter of Khuwaylid, and Fatimah daughter of Muhammad."',
              bn: 'নবী (সা.) বলেছেন: "দুনিয়ার শ্রেষ্ঠ নারী চারজন: ইমরানের কন্যা মারইয়াম, ফিরাউনের স্ত্রী আসিয়া, খুওয়াইলিদের কন্যা খাদীজা এবং মুহাম্মাদের কন্যা ফাতিমা।"',
              ar: 'قال النبي ﷺ: "خَيْرُ نِسَاءِ الْعَالَمِينَ أَرْبَعٌ: مَرْيَمُ بِنْتُ عِمْرَانَ، وَآسِيَةُ امْرَأَةُ فِرْعَوْنَ، وَخَدِيجَةُ بِنْتُ خُوَيْلِدٍ، وَفَاطِمَةُ بِنْتُ مُحَمَّدٍ"'
            },
            grade: 'sahih'
          }
        ]
      }
    ]
  },
  {
    id: 'isa-ch-02',
    title: 'The Annunciation: A Word from Allah and the Miraculous Conception',
    summary: 'The angels brought Maryam the most extraordinary news ever given to a woman: she would bear a son — Al-Masih Isa — conceived without a father, created by the word "Be." Allah sent His spirit (Jibril) in the form of a perfect man to announce this miracle. Maryam\'s response was one of wonder, humility, and ultimately total submission to Allah\'s decree.',
    order: 2,
    paragraphs: [
      {
        id: 'isa-ch02-p01',
        text: 'The angels brought Maryam the most momentous news ever delivered to a human being: "O Maryam, indeed Allah gives you good tidings of a word from Him, whose name will be the Messiah, Isa, the son of Maryam — distinguished in this world and the Hereafter and among those brought near [to Allah]. He will speak to the people in the cradle and in maturity and will be of the righteous." The description of Isa as "a word from Him" (kalimah minhu) is profoundly significant. Ibn Kathir explains that Isa is called "a word" because he came into existence through Allah\'s creative command "Be" (kun) — without the normal means of human conception. He was not "the Word of God" in the sense of being divine, but rather a creation brought about by the divine word of command. The title "Al-Masih" (the Messiah/the Anointed) was given to him by Allah Himself, and he was to be known always as "son of Maryam" — a unique distinction, as prophets are normally identified through their fathers. Maryam was astonished: "My Lord, how will I have a child when no man has touched me?" The angel replied: "Such is Allah; He creates what He wills. When He decrees a matter, He only says to it \'Be,\' and it is." This answer places Isa\'s creation in perspective — it was an act of divine power, no more difficult for Allah than the creation of Adam from dust or any other miracle.',
        phase: 'quran',
        references: [
          {
            type: 'quran',
            surah: 3,
            surahName: { en: 'Al-Imran', bn: 'আলে-ইমরান', ar: 'آل عمران' },
            ayahStart: 45,
            ayahEnd: 47,
            arabicText: 'إِذْ قَالَتِ الْمَلَائِكَةُ يَا مَرْيَمُ إِنَّ اللَّهَ يُبَشِّرُكِ بِكَلِمَةٍ مِّنْهُ اسْمُهُ الْمَسِيحُ عِيسَى ابْنُ مَرْيَمَ وَجِيهًا فِي الدُّنْيَا وَالْآخِرَةِ وَمِنَ الْمُقَرَّبِينَ وَيُكَلِّمُ النَّاسَ فِي الْمَهْدِ وَكَهْلًا وَمِنَ الصَّالِحِينَ قَالَتْ رَبِّ أَنَّىٰ يَكُونُ لِي وَلَدٌ وَلَمْ يَمْسَسْنِي بَشَرٌ ۖ قَالَ كَذَٰلِكِ اللَّهُ يَخْلُقُ مَا يَشَاءُ ۚ إِذَا قَضَىٰ أَمْرًا فَإِنَّمَا يَقُولُ لَهُ كُن فَيَكُونُ',
            translation: {
              en: '[Mention] when the angels said, "O Maryam, indeed Allah gives you good tidings of a word from Him, whose name will be the Messiah, Isa, the son of Maryam — distinguished in this world and the Hereafter and among those brought near [to Allah]. He will speak to the people in the cradle and in maturity and will be of the righteous." She said, "My Lord, how will I have a child when no man has touched me?" [The angel] said, "Such is Allah; He creates what He wills. When He decrees a matter, He only says to it \'Be,\' and it is."',
              bn: 'যখন ফেরেশতারা বলল, "হে মারইয়াম, নিশ্চয়ই আল্লাহ তোমাকে তাঁর পক্ষ থেকে একটি কালিমার সুসংবাদ দিচ্ছেন, যার নাম হবে মাসীহ ঈসা ইবনে মারইয়াম — দুনিয়া ও আখিরাতে সম্মানিত এবং নৈকট্যপ্রাপ্তদের অন্তর্ভুক্ত। সে মানুষের সাথে দোলনায় ও পরিণত বয়সে কথা বলবে এবং সে সৎকর্মশীলদের অন্তর্ভুক্ত হবে।" সে বলল, "হে আমার রব, কীভাবে আমার সন্তান হবে যখন কোনো মানুষ আমাকে স্পর্শ করেনি?" তিনি বললেন, "এভাবেই আল্লাহ যা ইচ্ছা সৃষ্টি করেন। তিনি যখন কোনো বিষয়ের সিদ্ধান্ত নেন, তখন শুধু বলেন \'হও\' আর তা হয়ে যায়।"',
              ar: 'إِذْ قَالَتِ الْمَلَائِكَةُ يَا مَرْيَمُ إِنَّ اللَّهَ يُبَشِّرُكِ بِكَلِمَةٍ مِّنْهُ اسْمُهُ الْمَسِيحُ عِيسَى ابْنُ مَرْيَمَ وَجِيهًا فِي الدُّنْيَا وَالْآخِرَةِ وَمِنَ الْمُقَرَّبِينَ وَيُكَلِّمُ النَّاسَ فِي الْمَهْدِ وَكَهْلًا وَمِنَ الصَّالِحِينَ قَالَتْ رَبِّ أَنَّىٰ يَكُونُ لِي وَلَدٌ وَلَمْ يَمْسَسْنِي بَشَرٌ ۖ قَالَ كَذَٰلِكِ اللَّهُ يَخْلُقُ مَا يَشَاءُ ۚ إِذَا قَضَىٰ أَمْرًا فَإِنَّمَا يَقُولُ لَهُ كُن فَيَكُونُ'
            }
          }
        ]
      },
      {
        id: 'isa-ch02-p02',
        text: 'Surah Maryam provides the most intimate account of the conception. Maryam had withdrawn from her family to a place in the east — likely for worship and seclusion. There, Allah sent to her "Our Spirit" (Ruh) — the angel Jibril — who appeared before her in the form of a perfectly proportioned man. Alarmed, Maryam said: "Indeed, I seek refuge in the Most Merciful from you, [so leave me], if you should be fearing of Allah." Her first instinct was to invoke Allah\'s protection — a testament to her piety and chastity. The angel reassured her: "I am only the messenger of your Lord to give you [news of] a pure boy." Again she asked how this could be when no man had ever touched her and she had never been unchaste. He replied: "Thus [it will be]; your Lord says, \'It is easy for Me, and We will make him a sign to the people and a mercy from Us. And it is a matter [already] decreed.\'" Ibn Kathir explains that Jibril then breathed into the opening of her garment, and this breath — by Allah\'s command — caused her to conceive Isa. The Quran states elsewhere: "And she who guarded her chastity, so We breathed into her through Our angel, and We made her and her son a sign for the worlds." Isa\'s conception was thus entirely miraculous — a sign of Allah\'s power, a mercy to humanity, and a matter that Allah had decreed long before it happened.',
        phase: 'quran',
        references: [
          {
            type: 'quran',
            surah: 19,
            surahName: { en: 'Maryam', bn: 'মারইয়াম', ar: 'مريم' },
            ayahStart: 17,
            ayahEnd: 21,
            arabicText: 'فَأَرْسَلْنَا إِلَيْهَا رُوحَنَا فَتَمَثَّلَ لَهَا بَشَرًا سَوِيًّا قَالَتْ إِنِّي أَعُوذُ بِالرَّحْمَٰنِ مِنكَ إِن كُنتَ تَقِيًّا قَالَ إِنَّمَا أَنَا رَسُولُ رَبِّكِ لِأَهَبَ لَكِ غُلَامًا زَكِيًّا قَالَتْ أَنَّىٰ يَكُونُ لِي غُلَامٌ وَلَمْ يَمْسَسْنِي بَشَرٌ وَلَمْ أَكُ بَغِيًّا قَالَ كَذَٰلِكِ قَالَ رَبُّكِ هُوَ عَلَيَّ هَيِّنٌ ۖ وَلِنَجْعَلَهُ آيَةً لِّلنَّاسِ وَرَحْمَةً مِّنَّا ۚ وَكَانَ أَمْرًا مَّقْضِيًّا',
            translation: {
              en: 'Then We sent to her Our Spirit, and he represented himself to her as a well-proportioned man. She said, "Indeed, I seek refuge in the Most Merciful from you, [so leave me], if you should be fearing of Allah." He said, "I am only the messenger of your Lord to give you [news of] a pure boy." She said, "How can I have a boy while no man has touched me and I have not been unchaste?" He said, "Thus [it will be]; your Lord says, \'It is easy for Me, and We will make him a sign to the people and a mercy from Us. And it is a matter [already] decreed.\'"',
              bn: 'তারপর আমি তার কাছে আমার রূহ (জিবরীল) পাঠালাম, যে তার সামনে সুগঠিত মানুষের রূপ ধারণ করল। সে বলল, "আমি তোমার থেকে পরম করুণাময়ের কাছে আশ্রয় চাই, যদি তুমি আল্লাহভীরু হও।" সে বলল, "আমি তো তোমার রবের দূত মাত্র, তোমাকে একটি পবিত্র পুত্র সন্তান দান করতে এসেছি।" সে বলল, "কীভাবে আমার পুত্র হবে যখন কোনো পুরুষ আমাকে স্পর্শ করেনি এবং আমি ব্যভিচারিণীও নই?" সে বলল, "এভাবেই হবে। তোমার রব বলেছেন, \'এটা আমার পক্ষে সহজ। আমি তাকে মানুষের জন্য নিদর্শন ও আমার পক্ষ থেকে রহমত বানাব। এটা একটা সিদ্ধান্তকৃত বিষয়।\'"',
              ar: 'فَأَرْسَلْنَا إِلَيْهَا رُوحَنَا فَتَمَثَّلَ لَهَا بَشَرًا سَوِيًّا قَالَتْ إِنِّي أَعُوذُ بِالرَّحْمَٰنِ مِنكَ إِن كُنتَ تَقِيًّا قَالَ إِنَّمَا أَنَا رَسُولُ رَبِّكِ لِأَهَبَ لَكِ غُلَامًا زَكِيًّا قَالَتْ أَنَّىٰ يَكُونُ لِي غُلَامٌ وَلَمْ يَمْسَسْنِي بَشَرٌ وَلَمْ أَكُ بَغِيًّا قَالَ كَذَٰلِكِ قَالَ رَبُّكِ هُوَ عَلَيَّ هَيِّنٌ ۖ وَلِنَجْعَلَهُ آيَةً لِّلنَّاسِ وَرَحْمَةً مِّنَّا ۚ وَكَانَ أَمْرًا مَّقْضِيًّا'
            }
          },
          {
            type: 'quran',
            surah: 21,
            surahName: { en: 'Al-Anbiya', bn: 'আল-আম্বিয়া', ar: 'الأنبياء' },
            ayahStart: 91,
            arabicText: 'وَالَّتِي أَحْصَنَتْ فَرْجَهَا فَنَفَخْنَا فِيهَا مِن رُّوحِنَا وَجَعَلْنَاهَا وَابْنَهَا آيَةً لِّلْعَالَمِينَ',
            translation: {
              en: 'And [mention] the one who guarded her chastity, so We breathed into her [garment] through Our angel [Jibril], and We made her and her son a sign for the worlds.',
              bn: 'আর সেই নারী যে তার সতীত্ব রক্ষা করেছিল, তাই আমি তার মধ্যে আমার রূহ (ফেরেশতার মাধ্যমে) ফুঁকে দিলাম এবং তাকে ও তার পুত্রকে সমগ্র বিশ্বের জন্য নিদর্শন বানালাম।',
              ar: 'وَالَّتِي أَحْصَنَتْ فَرْجَهَا فَنَفَخْنَا فِيهَا مِن رُّوحِنَا وَجَعَلْنَاهَا وَابْنَهَا آيَةً لِّلْعَالَمِينَ'
            }
          }
